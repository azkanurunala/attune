{
  "expo": {
    "name": "Attune",
    "slug": "attune",
    "scheme": "attune",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#05070D",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.attune.game",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Attune does not record you. This permission exists only because the game's audio engine links iOS audio-input APIs; the microphone is never accessed."
      },
      "entitlements": {
        "com.apple.developer.game-center": true
      }
    },
    "android": {
      "package": "com.attune.game",
      "permissions": [
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#05070D"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-status-bar",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#05070D",
          "resizeMode": "contain"
        }
      ],
      [
        "react-native-audio-api",
        {
          "iosBackgroundMode": false,
          "disableFFmpeg": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "60de682b-1c31-4925-b79c-75f167756084"
      }
    },
    "owner": "azkanura"
  }
}
